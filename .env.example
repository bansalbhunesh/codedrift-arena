# Copy to .env and fill in. Values below are placeholders.
# Training deps: pip install -r requirements-train.txt
# Space deps:     root requirements.txt (Gradio only)

CODEDRIFT_MODEL_ID=unsloth/Qwen2.5-1.5B-Instruct
CODEDRIFT_OUTPUT_DIR=./codedrift_output

# Leave blank until you have real repos (cleaner logs).
CODEDRIFT_HF_DATASET_REPO=
CODEDRIFT_HF_MODEL_REPO=
CODEDRIFT_HF_SPACE_URL=

WANDB_PROJECT=
WANDB_ENTITY=

OPENENV_HOST=0.0.0.0
OPENENV_PORT=8000

# --- API/server hardening ------------------------------------------------------
# Global request controls
CODEDRIFT_API_RATE_LIMIT_RPM=120
CODEDRIFT_API_MAX_BODY_BYTES=262144

# Auth mode
# - Set REQUIRE_AUTH=1 for protected deployments.
# - Use either legacy CODEDRIFT_API_TOKEN OR scoped read/write tokens.
CODEDRIFT_REQUIRE_AUTH=0
CODEDRIFT_API_TOKEN=
CODEDRIFT_API_READ_TOKEN=
CODEDRIFT_API_WRITE_TOKEN=

# Session safety + lifecycle
CODEDRIFT_SESSION_TTL_SECONDS=900
CODEDRIFT_SESSION_SIGNING_KEY=change-me-strong-secret
CODEDRIFT_SESSION_PREVIOUS_SIGNING_KEYS=
CODEDRIFT_SESSION_MIN_SUPPORTED_SCHEMA_VERSION=1

# Metrics policy: public | read | write
CODEDRIFT_METRICS_ACCESS=public

# Optional distributed state (rate limiting + sessions)
CODEDRIFT_REDIS_URL=

# Cap in-memory sessions when Redis is not used (DoS / memory safety)
CODEDRIFT_MAX_IN_MEMORY_SESSIONS=2000

# Logging
CODEDRIFT_LOG_LEVEL=INFO
CODEDRIFT_LOG_FORMAT=text
